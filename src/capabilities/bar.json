{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "bar",
  "description": "Least-privilege capability for the HUD bar window",
  "windows": ["bar"],
  "permissions": [
    "core:default",
    "allow-get-config",
    "allow-has-soniox-key",
    "allow-create-soniox-temporary-key",
    "allow-has-xai-key",
    "allow-has-openai-compatible-key",
    "allow-ensure-microphone-permission",
    "allow-ensure-accessibility-permission",
    "allow-insert-text",
    "allow-correct-transcript",
    "allow-set-mic-state",
    "allow-show-bar",
    "allow-hide-bar",
    "allow-set-mouse-events",
    "allow-show-settings",
    "allow-get-platform-runtime-info",
    "allow-consume-pending-mic-toggle"
  ]
}
