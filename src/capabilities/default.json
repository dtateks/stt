{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for main and bar windows",
  "windows": ["main", "bar"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:tray:default",
    "global-shortcut:default",
    "shell:default",
    "clipboard-manager:default",
    "http:default"
  ]
}
